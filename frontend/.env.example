# Frontend (Vercel / Next.js) — set these in the Vercel project Environment Variables UI.
# Copy to .env.local for local Next.js dev: cp .env.example .env.local

# Deployed PYUSDSubscription contract address
NEXT_PUBLIC_CONTRACT_ADDRESS=0x3D8bE24704F15B7F290B986efced351f31e5B313

# PYUSD token contract on the target network
NEXT_PUBLIC_PYUSD_ADDRESS=0xCaC524BcA292aaade2DF8A05cC58F0a65B1B3bB9

# EVM chain ID (11155111 = Ethereum Sepolia)
NEXT_PUBLIC_CHAIN_ID=11155111

# Block explorer base URL for transaction links
NEXT_PUBLIC_EXPLORER_BASE_URL=https://sepolia.etherscan.io
